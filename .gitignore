```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.css.map

# Environment variables
.env
.env.local
*.env.*

# Editor files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Python cache (if applicable)
__pycache__/
*.pyc
*.pyo
*.pyd

# Coverage reports
coverage/
htmlcov/
.coverage

# Temporary files
*.tmp
*.temp
.DS_Store
Thumbs.db
```