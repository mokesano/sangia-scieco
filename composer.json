{
    "name": "sangia/scieco",
    "description": "Sangia Scieco sebagai Platform Pengukuran Dampak Riset",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "delight-im/auth": "^7.0",
        "vlucas/phpdotenv": "^5.5",
        "guzzlehttp/guzzle": "^7.0",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-curl": "*",
        "ext-redis": "*"
    },
    "autoload": {
        "psr-4": {
            "Wizdam\\App\\": "app/",
            "Wizdam\\": "app/",
            "Wizdam\\Library\\": "library/"
        },
        "files": [
            "library/Helpers/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"file_exists('storage/logs') || mkdir('storage/logs', 0755, true);\""
        ],
        "post-update-cmd": [
            "@php -r \"file_exists('storage/logs') || mkdir('storage/logs', 0755, true);\""
        ]
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "php-parallel-lint/php-parallel-lint": "^1.4",
        "phpcsstandards/phpcsextra": "^1.5",
        "phpcsstandards/phpcsutils": "^1.2",
        "phpunit/phpunit": "^11.5",
        "squizlabs/php_codesniffer": "^4.0"
    }
}
